{
  "compilerOptions": {
    "declaration": true,
    "importHelpers": true,
    "module": "commonjs",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": true,
    "target": "es2024",
    "declarationMap": true,
    "skipLibCheck": true,
    "strictNullChecks": true
  }
}
