{
  "name": "@example/multiple-tsconfigs",
  "private": true,
  "dependencies": {
    "@example/lib": "workspace:*"
  },
  "entrysmith": {
    "entrypoints": [
      "index.ts"
    ],
    "entrypointOutputMode": "esm",
    "typescript": {
      "tsConfigReferenceTargetPath": "tsconfig.build.json",
      "referenceTsConfigPaths": [
        "tsconfig.json",
        "tsconfig.build.json"
      ]
    },
    "packageOutputDirectory": "dist"
  }
}
